{
  "name": "urban-flat-kit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs');const p='.next';if(!fs.existsSync(p))process.exit(0);try{fs.rmSync(p,{recursive:true,force:true});}catch(e){if(e.code==='EPERM'||e.code==='EBUSY'){console.error('Could not delete .next (files in use). Stop all `next dev` / Node processes using this folder, then run npm run clean again.');process.exit(1);}throw e;}\"",
    "dev": "next dev",
    "dev:clean": "npm run clean && next dev",
    "build": "next build",
    "start": "npx serve out",
    "lint": "next lint",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:projects": "tsx scripts/migrateProjects.ts",
    "migrate:analytics-projectid": "tsx scripts/migrate-analytics-projectId.ts",
    "migrate:project-status": "tsx scripts/migrate-project-status.ts",
    "migrate:items-to-project1": "tsx scripts/migrate-items-to-project1.ts",
    "migrate:normalize-item-docids": "tsx scripts/migrate-normalize-item-docids.ts",
    "repair:item-image-urls": "tsx scripts/repair-item-image-urls.ts"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.35.0",
    "lucide-react": "^0.577.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^17.3.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
