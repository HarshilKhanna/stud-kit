# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files — never commit credentials
.env
.env.local
.env*.local

# Firebase
.firebase/

# Firebase service account keys — contain private keys, never commit
secrets/
!secrets/.gitkeep
*firebase-adminsdk*.json
student-kit-eee08-firebase-adminsdk-fbsvc-4e68f88cfe.json

# App Hosting config contains env var values (API keys etc.)
apphosting.yaml

# Claude Code local settings
.claude/
public/.claude/

# Misc build artifacts
build_log.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
